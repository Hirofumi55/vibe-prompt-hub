---
import { pwaInfo } from 'virtual:pwa-info';
import Header from '../components/common/Header.astro';
import Footer from '../components/common/Footer.astro';
import ToastViewport from '../components/common/ToastViewport.astro';
import { toSafeJson } from '../lib/json';
import { SITE } from '../lib/site';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalPath?: string;
  noindex?: boolean;
  currentPath?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const {
  title,
  description = SITE.description,
  image = SITE.ogImage,
  canonicalPath = Astro.url.pathname,
  noindex = false,
  currentPath = Astro.url.pathname,
  structuredData,
} = Astro.props;

const pageTitle = title ? `${title} | ${SITE.name}` : SITE.name;
const canonical = new URL(canonicalPath, SITE.origin).toString();
const socialImage = new URL(image, SITE.origin).toString();
const structuredDataList = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
---

<!doctype html>
<html lang="ja" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={SITE.themeColor} />
    <meta name="theme-color" content={SITE.themeColor} media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#f8f6ff" media="(prefers-color-scheme: light)" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content={noindex ? 'noindex,nofollow' : 'index,follow'} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/icons/apple-touch-icon.png" />
    {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}

    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta property="og:image:alt" content={pageTitle} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />

    <script is:inline>
      (() => {
        const storageKey = 'prompt-hub:theme';
        const stored = localStorage.getItem(storageKey);
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        const theme = stored === 'light' || stored === 'dark' ? stored : prefersDark ? 'dark' : 'light';
        const root = document.documentElement;
        root.classList.toggle('dark', theme === 'dark');
        root.dataset.theme = theme;
        root.style.colorScheme = theme;
      })();
    </script>

    {structuredDataList.map((schema) => (
      <script is:inline type="application/ld+json" set:html={toSafeJson(schema)} />
    ))}
  </head>
  <body>
    <Header currentPath={currentPath} />
    <main class="shell flex flex-col gap-6 py-6 md:gap-8 md:py-8">
      <slot />
    </main>
    <Footer />
    <ToastViewport />
    {pwaInfo?.registerSW?.scriptTag && <Fragment set:html={pwaInfo.registerSW.scriptTag} />}

    <script>
      import { initGlobalUi } from '../scripts/global';

      initGlobalUi();
    </script>
  </body>
</html>
