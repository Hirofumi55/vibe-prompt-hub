---
import PromptCard from '../components/prompts/PromptCard.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { prompts } from '../data/prompts';
---

<BaseLayout
  title="お気に入り"
  description="保存しておいたプロンプトを一覧で見返せるローカル専用ページ。"
  currentPath="/favorites/"
  canonicalPath="/favorites/"
  noindex
>
  <section class="section-shell px-5 py-6 sm:px-7" data-favorites-page>
    <p class="eyebrow">Favorites</p>
    <div class="mt-2 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
      <div>
        <h1 class="text-3xl font-bold text-text">お気に入り</h1>
        <p class="mt-3 max-w-2xl text-sm leading-7 text-text-soft">
          よく使うプロンプトをローカルに保存しておけます。ブラウザごとに保持されるので、いつもの端末ではすぐ再利用できます。
        </p>
      </div>
      <span class="chip">保存中 <span class="font-bold text-text" data-favorites-count>0件</span></span>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3" data-favorites-grid></div>

    <div class="mt-6 rounded-[1.75rem] border border-dashed border-line px-5 py-8 text-sm leading-7 text-text-soft" data-favorites-empty>
      まだお気に入りはありません。各カードの「お気に入り」を押すと、このページにすぐ戻せる定番プロンプトとして保存されます。
    </div>
  </section>

  <div id="favorites-card-pool" class="hidden" aria-hidden="true">
    {prompts.map((prompt) => (
      <PromptCard prompt={prompt} compact />
    ))}
  </div>

  <script>
    import { initFavoritesPage } from '../scripts/favorites';

    initFavoritesPage();
  </script>
</BaseLayout>
